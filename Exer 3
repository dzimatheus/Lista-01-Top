#include <stdio.h>
#include <math.h>

int ehPrimo(int num) {
    if (num < 2) return 0;

    for (int i = 2; i <= sqrt(num); i++) {
        if (num % i == 0) return 0;
    }

    return 1;
}

int main() {
    int n, num, contador = 0;

    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        scanf("%d", &num);

        if (ehPrimo(num)) {
            contador++;
        }
    }

    printf("Quantidade de primos: %d\n", contador);

    return 0;
}
