#include <stdio.h>

int mdc(int a, int b) {
    int resto;
    
    while (b != 0) {
        resto = a % b;
        a = b;
        b = resto;
    }
    
    return a;
}

int mmc(int a, int b) {
    return (a * b) / mdc(a, b);
}

int main() {
    int a, b;

    scanf("%d %d", &a, &b);

    int mdcc = mdc(a, b);
    int mmcc = mmc(a, b);

    printf("MDC = %d\n", mdcc);
    printf("MMC = %d\n", mmcc);

    return 0;
}
